scripts/gemini-validation/validation-review.json
infrastructure/keys/

# Deno
deno.lock

# Local one-off debug scripts (kept locally, never committed)
check-*.mjs

# Phase 4 training data — clips + sidecars, multi-GB, never committed
training-data/

# Dev-server build dir (separate from .next so `next build` cannot clobber a running dev server)
.next-dev/

# Local judge assets for /panorama-test — the deployed page takes URL params;
# these raw VP videos + mesh copies are local-only (~165MB, regenerable from
# Supabase storage / CloudFront)
public/vp-mesh*/
public/vp-*.mp4
public/panorama-test.mp4

# Lambda layer build artifacts (rebuilt from layer scripts)
infrastructure/lambda/layers/

# Phase-4 training workspace — clips + model outputs, multi-GB
scripts/phase4/

# Portrait-crop mining data (raw match footage + detections, 14GB)
scripts/portrait-crop/mining/

# Eval-dataset detection caches — regenerable by re-running the detectors;
# labels/ (human + oracle ground truth) stays tracked
scripts/portrait-crop/eval-dataset/clips/*.json

# Fetched Spiideo calibration meshes — re-fetchable via fetch_spiideo_mesh.mjs;
# canonical copies live in Supabase storage
scripts/follow-re/spiideo-real-mesh-*/

# Follow-re research resume doc — local working notes; quotes operational IDs
# that trip Netlify's secrets scanner (2026-07-14 incident)
scripts/follow-re/AIM_RESUME.md

# Player-identity research working data — re-fetchable via fetch_tracklets.py
# (Spiideo items persist ~72d) or re-derivable from the raw panorama; the
# scripts + README stay tracked
scripts/player-identity/cache/
scripts/player-identity/crops/
scripts/player-identity/mesh/
scripts/player-identity/prod-solve.json
scripts/player-identity/*.png
